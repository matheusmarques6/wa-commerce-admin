# ══════════════════════════════════════════
# SUPABASE - pegar no dashboard do Supabase
# Settings → API
# ══════════════════════════════════════════

# URL do projeto (ex: https://xxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Anon key (pública, usada no frontend)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key (SECRETA, usada só no server)
SUPABASE_SERVICE_ROLE_KEY=
